musb: host - suniv DMA fixes to musb_host_rx/urb-cleanup (PIO fallback + flush)

Three host-path fixes needed by the sunxi_dma backend, which (unlike inventra/ux500)
gates short/misaligned transfers to PIO and shares ONE FIFO datapath between PIO
and DMA via a global VEND0 BUS_SEL bit (reg 0x43):

1) musb_host_rx(): when musb_rx_dma_in_inventra_cppi41() declines the RX DMA
   (channel_program returns 0 for a short transfer) the helper released
   hw_ep->rx_channel, but the caller's local `dma` still pointed at it, so the
   `if (!dma)` PIO block was skipped and the packet was dropped -> the AA session
   stalled after "Accessory linked". Refresh the local `dma` (now NULL) so RX
   falls through to PIO, mirroring the TX fallback.

2) musb_h_tx_flush_fifo(): a contended or NAKing OUT packet (e.g. an AA bulk-OUT
   write that collided with the RX video DMA on the shared datapath) can leave
   FIFONOTEMPTY set. The stock 1000 x mdelay(1) = up to 1s spin then runs with
   IRQs off under musb->lock and starves the realtime aa-read thread ->
   "sched: RT throttling activated" -> the app drops the AA link (observed:
   "Could not flush host TX2 fifo: csr 2003" WARNING at musb_host.c:113, then a
   LIBUSB_ERROR_TIMEOUT bulk write and reconnect). Bound the spin to a few us on
   suniv and drop the WARN (a jammed FIFO is expected on this IC, not a bug); a
   still-stale FIFO is discarded when the endpoint is next programmed and the app
   re-sends the OUT transfer. Fixes all callers, not just urb-cleanup.

3) musb_cleanup_urb(): return the shared datapath to PIO only if THIS tx ep owned
   the DMA (already aborted upstream); never clear BUS_SEL / abort the RX channel
   when the RX video DMA owns it -- that corrupts the in-flight video (ep2 RX
   three-strikes -> re-enumeration). Gated on CONFIG_USB_SUNXI_DMA so only suniv
   builds touch reg 0x43.

Signed-off-by: mbt28 <btekbas@gmail.com>

--- a/drivers/usb/musb/musb_host.c
+++ b/drivers/usb/musb/musb_host.c
@@ -88,7 +88,22 @@
 	struct musb	*musb = ep->musb;
 	void __iomem	*epio = ep->regs;
 	u16		csr;
+#if IS_ENABLED(CONFIG_USB_SUNXI_DMA)
+	/*
+	 * suniv has ONE shared FIFO datapath. A contended or NAKing OUT
+	 * packet can leave FIFONOTEMPTY set here (e.g. an AA bulk-OUT write
+	 * that collided with the RX video DMA), and this runs under
+	 * musb->lock with IRQs off. The stock 1000 x mdelay(1) = up to 1s
+	 * spin then starves the realtime aa-read thread -> "sched: RT
+	 * throttling activated" -> the app drops the AA link. Bound the
+	 * spin to a few microseconds and move on; a still-stale FIFO is
+	 * discarded when the endpoint is next programmed and the app
+	 * re-sends the OUT transfer. Not a bug on this IC, so no WARN.
+	 */
+	int		retries = 4;
+#else
 	int		retries = 1000;
+#endif
 
 	csr = musb_readw(epio, MUSB_TXCSR);
 	while (csr & MUSB_TXCSR_FIFONOTEMPTY) {
@@ -96,6 +111,15 @@
 		musb_writew(epio, MUSB_TXCSR, csr);
 		csr = musb_readw(epio, MUSB_TXCSR);
 
+#if IS_ENABLED(CONFIG_USB_SUNXI_DMA)
+		if (retries-- < 1) {
+			dev_dbg(musb->controller,
+				"TX%d fifo not flushed (csr %04x); left for next ep program\n",
+				ep->epnum, csr);
+			return;
+		}
+		udelay(10);
+#else
 		/*
 		 * FIXME: sometimes the tx fifo flush failed, it has been
 		 * observed during device disconnect on AM335x.
@@ -115,6 +139,7 @@
 				ep->epnum, csr))
 			return;
 		mdelay(1);
+#endif
 	}
 }
 
@@ -1924,8 +1949,14 @@
 			if (musb_rx_dma_in_inventra_cppi41(c, hw_ep, qh, urb,
 							   xfer_len, iso_err))
 				goto finish;
-			else
-				dev_err(musb->controller, "error: rx_dma failed\n");
+			/*
+			 * The DMA backend declined this RX (e.g. a short
+			 * transfer the sunxi engine rejects): the helper has
+			 * already released rx_channel, so drop our stale local
+			 * ref and fall through to the PIO path below instead of
+			 * losing the packet.  Mirrors the TX PIO fallback.
+			 */
+			dma = hw_ep->rx_channel;
 		}
 
 		if (!dma) {
@@ -2339,6 +2370,24 @@
 		if (is_dma_capable() && dma)
 			musb_platform_clear_ep_rxintr(musb, ep->epnum);
 	} else if (ep->epnum) {
+#if IS_ENABLED(CONFIG_USB_SUNXI_DMA)
+		/*
+		 * suniv shares one FIFO datapath + one dedicated-DMA channel
+		 * between TX and RX via the global VEND0 BUS_SEL bit (reg 0x43).
+		 * Return the datapath to PIO only if THIS tx ep owned the DMA
+		 * (`dma`, already aborted above); NEVER clear BUS_SEL or abort
+		 * the RX channel when the RX video DMA owns it -- that corrupts
+		 * the in-flight video (ep2 RX three-strikes -> disconnect ->
+		 * re-enumeration storm). musb_h_tx_flush_fifo() is bounded on
+		 * suniv (see its top) so it can't spin 1s / trip RT throttling.
+		 */
+		if (is_dma_capable() && dma) {
+			writeb(0, musb->mregs + 0x43);
+			csr = musb_readw(epio, MUSB_TXCSR);
+			csr &= ~(MUSB_TXCSR_DMAENAB | MUSB_TXCSR_DMAMODE);
+			musb_writew(epio, MUSB_TXCSR, csr);
+		}
+#endif
 		musb_h_tx_flush_fifo(ep);
 		csr = musb_readw(epio, MUSB_TXCSR);
 		csr &= ~(MUSB_TXCSR_AUTOSET
