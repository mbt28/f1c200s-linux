 	help
 	  Enable DMA transfers on UX500 platforms.
 
+config USB_SUNXI_DMA
+	bool 'Allwinner sunxi'
+	depends on USB_MUSB_SUNXI && DMADEVICES
+	help
+	  Enable DMA transfers for the Allwinner sunxi/suniv MUSB glue using
+	  the SoC's dedicated-DMA engine (sun4i-dma) to move the USB endpoint
+	  FIFOs to/from SDRAM, offloading the CPU (PIO) copy.  Falls back to
+	  PIO automatically if the DT does not wire the "rx"/"tx" dmas.
+
 config USB_INVENTRA_DMA
 	bool 'Inventra'
 	depends on USB_MUSB_OMAP2PLUS || USB_MUSB_MEDIATEK || USB_MUSB_JZ4740 || USB_MUSB_POLARFIRE_SOC
