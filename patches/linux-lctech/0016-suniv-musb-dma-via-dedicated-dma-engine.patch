+#define SUNXI_MUSB_DMA_QUIRK	MUSB_DMA_UX500
+#else
 static struct dma_controller *
 sunxi_musb_dma_controller_create(struct musb *musb, void __iomem *base)
 {
@@ -326,6 +349,9 @@
