# f1c200s-linux — pinned upstream versions and sources.
# Sourced by scripts/fetch-sources.sh and scripts/build.sh. Edit to re-pin.

# --- Buildroot (fetched here; it in turn downloads the kernel + U-Boot) ---
BUILDROOT_VERSION="2026.05"
BUILDROOT_GIT="https://gitlab.com/buildroot.org/buildroot.git"

# --- Kernel / U-Boot versions live in the DEFCONFIG (single source of truth) ---
# Edit BR2_LINUX_KERNEL_CUSTOM_VERSION_VALUE / BR2_TARGET_UBOOT_CUSTOM_VERSION_VALUE
# in configs/$DEFCONFIG; the scripts read them from there (no copy to keep in sync).
# NOTE: kernel.org only keeps the latest point release of each series as a tarball;
# older ones 404. Keep the kernel at (or near) the current LTS, or drop the tarball
# into buildroot/dl/linux/.

# --- Cedar VE + ION driver (BSP decode path), injected into the kernel tree ---
# by external.mk's CEDAR_INTEGRATE hook from cedar/src.
CEDAR_GIT="https://github.com/mbt28/cedar.git"
CEDAR_REF="master"

# --- Buildroot external tree identity (defconfig references BR2_EXTERNAL_CARPLAY_PATH) ---
BR2_EXTERNAL_NAME="CARPLAY"
DEFCONFIG="lctech_pi_f1c200s_sdcard_defconfig"

# --- Working directories (git-ignored; created by the scripts) ---
# Buildroot checkout and the out-of-tree build output live here.
BUILDROOT_DIR="buildroot"
OUTPUT_DIR="output"
