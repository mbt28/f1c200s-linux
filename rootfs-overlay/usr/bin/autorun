#!/bin/sh
# autorun on|wireless|off|status|stop -- FastCarPlay boot-autostart control.
# on/wireless/off persist across reboots (flag files on the ext4 rootfs).
#   on        autostart the default preset (chosen from /etc/ve-driver)
#   wireless  autostart wireless Android Auto (settings_cedrus_wireless.txt);
#             S99carplay brings up wifi+bt+net first
case "$1" in
on)
	rm -f /etc/carplay-preset
	echo enabled > /etc/carplay-autostart
	echo "autostart enabled (default preset; from next boot -- run 'carplay' to launch now)"
	;;
wireless)
	echo cedrus_wireless > /etc/carplay-preset
	echo enabled > /etc/carplay-autostart
	echo "wireless AA autostart enabled (wifi+bt+net then FastCarPlay, from next boot)"
	;;
off)
	rm -f /etc/carplay-autostart
	echo "autostart disabled (running instance untouched; 'autorun stop' kills it)"
	;;
stop)
	killall fastcarplay 2>/dev/null && echo "stopped" || echo "not running"
	;;
status)
	if [ -f /etc/carplay-autostart ]; then
		echo "autostart: enabled (preset: $(cat /etc/carplay-preset 2>/dev/null || echo '<ve-driver>'))"
	else
		echo "autostart: disabled"
	fi
	if pidof fastcarplay > /dev/null 2>&1; then echo "fastcarplay: running (pid $(pidof fastcarplay))"; else echo "fastcarplay: not running"; fi
	;;
*)
	echo "usage: autorun on|wireless|off|status|stop"
	;;
esac
