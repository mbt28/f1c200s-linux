#!/bin/sh
# autorun on|wireless|off|status|stop -- FastCarPlay boot-autostart control.
# on/wireless/off persist across reboots (flag files on the ext4 rootfs).
#   wireless  wireless Android Auto appliance: the WiFi+BT radios (S45aa-stack)
#             AND the app (S99carplay) autostart at boot.
#   on        autostart the app with the default preset (from /etc/ve-driver);
#             no radios.
#   off       stop the APP autostart only. In wireless mode the WiFi+BT radios
#             stay up (S45aa-stack is independent) -- `bt off; wifi off` stops
#             those.
case "$1" in
on)
	rm -f /etc/carplay-preset
	echo enabled > /etc/carplay-autostart
	echo "app autostart enabled (default preset; from next boot -- run 'carplay' to launch now)"
	;;
wireless)
	echo cedrus_wireless > /etc/carplay-preset
	echo enabled > /etc/carplay-autostart
	echo "wireless AA enabled (WiFi+BT radios + FastCarPlay autostart, from next boot)"
	;;
off)
	rm -f /etc/carplay-autostart
	echo "app autostart disabled (running instance untouched; 'autorun stop' kills it)"
	grep -q wireless /etc/carplay-preset 2>/dev/null && \
		echo "  note: WiFi+BT radios still autostart (wireless mode) -- 'bt off; wifi off' to stop them"
	;;
stop)
	killall fastcarplay 2>/dev/null && echo "stopped" || echo "not running"
	;;
status)
	if [ -f /etc/carplay-autostart ]; then
		echo "app autostart: enabled (preset: $(cat /etc/carplay-preset 2>/dev/null || echo '<ve-driver>'))"
	else
		echo "app autostart: disabled"
	fi
	grep -q wireless /etc/carplay-preset 2>/dev/null && echo "radios (S45aa-stack): wireless mode ON" || echo "radios (S45aa-stack): off"
	pidof fastcarplay > /dev/null 2>&1 && echo "fastcarplay: running (pid $(pidof fastcarplay))" || echo "fastcarplay: not running"
	;;
*)
	echo "usage: autorun on|wireless|off|status|stop"
	;;
esac
