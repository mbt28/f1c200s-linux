#!/bin/sh
# Bluetooth runtime switch: HCI H4 over UART0/ttyS1 to the ESP32 running the
# CUSTOM spi+uart firmware (230400 baud, flow control off -- true 2-line
# UART, no CTS strap; docs/wireless-esp-hosted.md appendix). Independent of
# `wifi`: the ESP just has to be powered (VIN) and running that build.
#   bt on       system bus + bluetoothd + attach + power (idempotent)
#   bt off      tear everything down (NOTE: kills the system dbus too --
#               don't `bt off` under a running aa-wireless session)
#   bt status   adapter state in one look
case "$1" in
on)
	modprobe hci_uart 2>/dev/null
	# SMP needs cmac/ecdh at power-on; modprobe explicitly in case
	# crypto autoload is slow.
	modprobe cmac 2>/dev/null
	modprobe ecdh_generic 2>/dev/null
	if ! pidof dbus-daemon >/dev/null; then
		mkdir -p /var/run/dbus /var/lib/dbus 2>/dev/null
		# Stale remnants block a restart: THIS build's dbus pidfile
		# is /run/dbus-daemon.pid (not /var/run/dbus/pid), and an
		# orphaned socket gives clients "Connection refused".
		rm -f /run/dbus-daemon.pid /var/run/dbus/pid /var/run/dbus/system_bus_socket
		dbus-uuidgen --ensure 2>/dev/null
		dbus-daemon --system || echo "bt: dbus-daemon failed to start"
	fi
	i=0
	while [ $i -lt 5 ] && [ ! -S /var/run/dbus/system_bus_socket ]; do sleep 1; i=$((i + 1)); done
	# Adapter attached (registers hci0, down) BEFORE bluetoothd, which
	# adopts it via the kernel MGMT interface.
	pidof hciattach >/dev/null || {
		hciattach /dev/ttyS1 any 230400 noflow || {
			echo "bt: hciattach failed (ESP running the spi+uart firmware? wiring?)"
			exit 1
		}
	}
	BTD="$(command -v bluetoothd || echo /usr/libexec/bluetooth/bluetoothd)"
	# bluez 5.x bluetoothd does NOT daemonize -- background it, or this
	# script never returns (field-hit 2026-07-10). --compat enables the
	# legacy SDP interface so `sdptool browse local` can verify the HFP-AG
	# record (harmless otherwise; the phone uses native SDP either way).
	pidof bluetoothd >/dev/null || "$BTD" --experimental --compat >/dev/null 2>&1 &
	# Wait for org.bluez to appear on the bus (up to ~6 s) instead of a
	# blind sleep -- a premature adoption check triggers the destructive
	# re-attach heal against a perfectly healthy adapter.
	adopted() {
		dbus-send --system --reply-timeout=3000 --print-reply --dest=org.bluez / \
			org.freedesktop.DBus.ObjectManager.GetManagedObjects 2>/dev/null \
			| grep -q "/org/bluez/hci0"
	}
	i=0
	until adopted || [ $i -ge 3 ]; do sleep 2; i=$((i + 1)); done
	# Self-heal: a failed first power-up leaves hci0 PERMANENTLY hidden
	# from MGMT (raw HCI works, bluetoothd sees nothing; field-debugged
	# 2026-07-09). A fresh attach mints a clean, adoptable device.
	if ! adopted; then
		killall hciattach 2>/dev/null
		sleep 1
		hciattach /dev/ttyS1 any 230400 noflow
		sleep 2
	fi
	# Power through bluetoothd (mgmt path), matching what the app does.
	dbus-send --system --reply-timeout=5000 --print-reply --dest=org.bluez /org/bluez/hci0 \
		org.freedesktop.DBus.Properties.Set string:org.bluez.Adapter1 \
		string:Powered variant:boolean:true >/dev/null 2>&1 || hciconfig hci0 up
	adopted && echo "bt: hci0 managed by bluetoothd" || echo "bt: WARNING hci0 not adopted (check bluetoothd)"
	hciconfig hci0 | sed -n 2,3p
	# HFP Audio Gateway: the phone gates wireless Android Auto on the head
	# unit exposing a WORKING HFP-AG (0x111f) that completes the RFCOMM
	# service-level connection (AT+BRSF/AT+CIND/AT+CMER). bluez does NOT
	# answer that AT dialog; bluez-alsa's native backend does. No modem/call
	# audio -- only the SLC must complete. Start it once bluetoothd is up so
	# it can register the profile (on the reference Pi, PipeWire's bluez5 SPA
	# plugin filled this role; we ship the lighter bluez-alsa).
	# NB: the daemon is `bluealsa` in bluez-alsa v4.3.1 (Buildroot 2026.05);
	# it is renamed `bluealsad` only in later releases.
	if ! pidof bluealsa >/dev/null; then
		bluealsa -p hfp-ag -i hci0 >/dev/null 2>&1 &
	fi
	;;
off)
	# Stop the HFP-AG first (it depends on bluetoothd). busybox has no
	# pkill; pidof+kill handles one or many pids.
	kill "$(pidof bluealsa)" 2>/dev/null
	hciconfig hci0 down 2>/dev/null
	killall bluetoothd 2>/dev/null
	killall dbus-daemon 2>/dev/null
	rm -f /run/dbus-daemon.pid /var/run/dbus/pid /var/run/dbus/system_bus_socket
	killall hciattach 2>/dev/null
	modprobe -r hci_uart 2>/dev/null
	echo "bt: off"
	;;
status)
	pidof hciattach >/dev/null && echo "hciattach:  running (ttyS1 @ 230400)" || echo "hciattach:  not running"
	if [ -d /sys/class/bluetooth/hci0 ]; then
		hciconfig hci0 | sed -n 1,3p
	else
		echo "hci0:       missing"
	fi
	pidof bluetoothd >/dev/null && echo "bluetoothd: running" || echo "bluetoothd: not running"
	pidof bluealsa >/dev/null && echo "bluealsa:   running (hfp-ag)" || echo "bluealsa:   not running"
	pidof dbus-daemon >/dev/null && echo "dbus:       running" || echo "dbus:       not running"
	;;
*)
	echo "usage: bt {on|off|status}"
	;;
esac
