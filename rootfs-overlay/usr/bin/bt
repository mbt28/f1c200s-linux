#!/bin/sh
# Bluetooth runtime switch: HCI H4 over UART0/ttyS1 to the ESP32 running the
# esp32/spi+uart firmware (fixed 921600 baud, its CTS strapped to GND --
# docs/wireless-esp-hosted.md). Independent of `wifi`: the ESP just has to be
# powered (it always is, VIN) and running the spi+uart build.
#   bt on       attach hci0 and bring it up
#   bt off      detach + unload
#   bt status   adapter state in one look
case "$1" in
on)
	modprobe hci_uart 2>/dev/null
	# Order matters for bluetoothd adoption: bus up -> adapter attached
	# (registers hci0, down) -> bluetoothd (adopts via mgmt) -> power on
	# through the MGMT path (btmgmt), never raw hciconfig alongside the
	# daemon. SMP needs cmac/ecdh at power-on; modprobe them explicitly
	# in case crypto autoload is slow/missing.
	if ! ps | grep -v grep | grep -q dbus-daemon; then
		mkdir -p /var/run/dbus
		rm -f /var/run/dbus/pid /var/run/dbus/system_bus_socket
		dbus-uuidgen --ensure 2>/dev/null
		dbus-daemon --system || echo "bt: dbus-daemon failed to start"
	fi
	i=0
	while [ $i -lt 5 ] && [ ! -S /var/run/dbus/system_bus_socket ]; do sleep 1; i=$((i + 1)); done
	modprobe cmac 2>/dev/null
	modprobe ecdh_generic 2>/dev/null
	ps | grep -v grep | grep -q hciattach || {
		hciattach /dev/ttyS1 any 921600 noflow || {
			echo "bt: hciattach failed (ESP running the spi+uart firmware? wiring?)"
			exit 1
		}
	}
	BTD="$(command -v bluetoothd || echo /usr/libexec/bluetooth/bluetoothd)"
	ps | grep -v grep | grep -q bluetoothd || "$BTD" --experimental 2>/dev/null
	sleep 1
	# Adoption check: a failed first power-up (marginal 921600 burst) leaves
	# hci0 PERMANENTLY hidden from the MGMT interface -- raw HCI still works
	# but bluetoothd manages nothing (no /org/bluez/hci0; field-debugged
	# 2026-07-09). A fresh attach mints a clean, adoptable device.
	adopted() {
		dbus-send --system --print-reply --dest=org.bluez / \
			org.freedesktop.DBus.ObjectManager.GetManagedObjects 2>/dev/null \
			| grep -q "/org/bluez/hci0"
	}
	if ! adopted; then
		killall hciattach 2>/dev/null
		sleep 1
		hciattach /dev/ttyS1 any 921600 noflow
		sleep 2
	fi
	# Power through bluetoothd (mgmt path), matching what the app does.
	dbus-send --system --print-reply --dest=org.bluez /org/bluez/hci0 \
		org.freedesktop.DBus.Properties.Set string:org.bluez.Adapter1 \
		string:Powered variant:boolean:true >/dev/null 2>&1 || hciconfig hci0 up
	adopted && echo "bt: hci0 managed by bluetoothd" || echo "bt: WARNING hci0 not adopted (check bluetoothd)"
	hciconfig hci0 | sed -n 2,3p
	;;
off)
	hciconfig hci0 down 2>/dev/null
	killall bluetoothd 2>/dev/null
	killall dbus-daemon 2>/dev/null
	rm -f /var/run/dbus/pid /var/run/dbus/system_bus_socket
	killall hciattach 2>/dev/null
	modprobe -r hci_uart 2>/dev/null
	echo "bt: off"
	;;
status)
	ps | grep -v grep | grep -q hciattach && echo "hciattach:  running (ttyS1 @ 921600)" || echo "hciattach:  not running"
	if [ -d /sys/class/bluetooth/hci0 ]; then
		hciconfig hci0 | sed -n 1,3p
	else
		echo "hci0:       missing"
	fi
	ps | grep -v grep | grep -q bluetoothd && echo "bluetoothd: running" || echo "bluetoothd: not running"
	ps | grep -v grep | grep -q dbus-daemon && echo "dbus:       running" || echo "dbus:       not running"
	;;
*)
	echo "usage: bt {on|off|status}"
	;;
esac
