#!/bin/sh
# FastCarPlay app autostart (last rcS step). Opt-out with `autorun off` -- that
# stops only the app; the WiFi + BT radios stay up (they come up in S45aa-stack,
# independent of this). The manual `carplay` command replaces a running
# instance. Log: /tmp/carplay.log
#
# Preset: an explicit /etc/carplay-preset (e.g. "cedrus_wireless", set by
# `autorun wireless`) wins; else it is derived from the active VE driver
# (/etc/ve-driver -> settings_<cedar|cedrus>.txt). For a *wireless* preset the
# radios are brought up by S45aa-stack; here we only wait for wlan0 + hci0 to be
# ready and then launch the app.

case "$1" in
start)
	[ -f /etc/carplay-autostart ] || exit 0
	# Preset from /etc/carplay-preset (set by `carplay-preset`); default is
	# cedrus_wireless (wireless Android Auto), then settings.txt as a last resort.
	name="$(cat /etc/carplay-preset 2>/dev/null)"
	[ -n "$name" ] || name=cedrus_wireless
	preset="/etc/fastcarplay/settings_${name}.txt"
	[ -f "$preset" ] || preset=/etc/fastcarplay/settings.txt
	echo "carplay: autostarting ($preset)"
	case "$preset" in
	*wireless*)
		# Wait for the radios (S45aa-stack) to be up, then launch. Backgrounded
		# so rcS is not blocked.
		( i=0
		  while [ $i -lt 45 ] && { [ ! -d /sys/class/net/wlan0 ] || [ ! -d /sys/class/bluetooth/hci0 ]; }; do
			sleep 1; i=$((i + 1))
		  done
		  SDL_AUDIODRIVER=dummy fastcarplay "$preset" > /tmp/carplay.log 2>&1
		) &
		;;
	*)
		SDL_AUDIODRIVER=dummy fastcarplay "$preset" > /tmp/carplay.log 2>&1 &
		;;
	esac
	;;
stop)
	killall fastcarplay 2>/dev/null
	;;
*)
	echo "Usage: $0 {start|stop}"
	;;
esac
