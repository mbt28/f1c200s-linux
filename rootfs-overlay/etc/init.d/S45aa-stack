#!/bin/sh
# Wireless-AA radios: bring up the ESP32 WiFi transport (wlan0) + the Bluetooth
# stack (dbus, bluetoothd, bluealsa HFP AG+HF, Audio+Telephony CoD) + the dev
# network, at boot, INDEPENDENT of the FastCarPlay app autostart. WiFi already
# had its own autostart (S43wifi); this gives Bluetooth the same independence,
# so `autorun off` (app off) still leaves WiFi + BT up. Gated on the preset
# needing radios: "wireless" (set by `autorun wireless`) or any "ui" preset
# (the LVGL UI offers wireless as a runtime source, so the radios must be up).
#
# Backgrounded: the ESP needs ~10-20 s to boot and rcS must not block. Order is
# load-bearing -- `wifi up` loads esp32_spi which pulls the ESP out of reset
# (PE4); `bt on`'s hciattach then finds a live controller over UART. The BT
# controller is briefly not ready right after that reset, so retry `bt on`
# until the adapter is actually UP RUNNING -- a dead UART link still registers
# an hci0 (BD 00:00.., DOWN), so mere /sys presence is NOT health.
# Progress is logged to /tmp/aa-stack.log.
case "$1" in
start)
	grep -qE 'wireless|ui' /etc/carplay-preset 2>/dev/null || exit 0
	(
		exec >> /tmp/aa-stack.log 2>&1
		echo "--- $(cut -d. -f1 /proc/uptime)s: start ---"
		wifi up
		echo "$(cut -d. -f1 /proc/uptime)s: wifi up rc=$? wlan0=$([ -d /sys/class/net/wlan0 ] && echo up || echo missing)"
		bt_up() { hciconfig hci0 2>/dev/null | grep -q "UP RUNNING"; }
		i=0
		until bt_up || [ $i -ge 5 ]; do
			[ $i -gt 0 ] && { bt off; sleep 2; }
			bt on
			i=$((i + 1))
			echo "$(cut -d. -f1 /proc/uptime)s: bt on try=$i hci0=$(bt_up && echo up || echo not-up)"
		done
		net on
		echo "--- $(cut -d. -f1 /proc/uptime)s: done hci0=$(bt_up && echo up || echo NOT-UP) ---"
	) &
	;;
stop)
	bt off 2>/dev/null
	;;
*)
	echo "usage: $0 {start|stop}"
	;;
esac
