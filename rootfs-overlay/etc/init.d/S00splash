#!/bin/sh
# Boot splash, runtime-selectable: blits the chosen theme (raw 480x272
# XRGB8888, gzipped) straight into /dev/fb0. Pick a theme ON THE BOARD with
#     echo 03-tux > /etc/splash-theme       (see /etc/splash/ for the list)
# -- it persists on the rootfs and shows from the next boot on. Preview
# instantly without rebooting:  zcat /etc/splash/03-tux.fb.gz > /dev/fb0
# The sun4i DRM pipeline defer-probes, so wait briefly for fb0.

case "$1" in
start)
	n=0
	while [ ! -e /dev/fb0 ] && [ "$n" -lt 50 ]; do
		usleep 100000 2>/dev/null || sleep 1
		n=$((n + 1))
	done
	[ -e /dev/fb0 ] || exit 0
	t=$(cat /etc/splash-theme 2>/dev/null | tr -dc 'a-z0-9-')
	[ -f "/etc/splash/${t}.fb.gz" ] || t=01-play-ring
	zcat "/etc/splash/${t}.fb.gz" > /dev/fb0 2>/dev/null
	;;
stop)
	;;
*)
	echo "Usage: $0 {start|stop}"
	;;
esac
